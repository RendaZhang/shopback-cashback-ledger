DATABASE_URL="postgresql://ledger:ledger@localhost:5432/ledger?schema=public"
KAFKA_BROKER=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379
SERVICE_NAME=sb-ledger-worker
POLL_INTERVAL_MS=1000
BATCH_SIZE=50
MAX_ATTEMPTS=5
EVENT_TOPIC=order.events
DLQ_TOPIC=order.events.dlq
CONSUMER_GROUP=sb-ledger-consumer
RETRY_POLL_INTERVAL_MS=1000
RETRY_BATCH_SIZE=50
METRICS_PORT=9100
METRICS_REFRESH_MS=2000
CASHBACK_RULE_CACHE_TTL_SECONDS=60
CASHBACK_RULE_CACHE_LOCK_MS=300
CASHBACK_RULE_CACHE_WAIT_MS=30
