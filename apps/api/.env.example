PORT=3000
THROTTLE_TTL=60
THROTTLE_LIMIT=600

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ledger
POSTGRES_USER=ledger
POSTGRES_PASSWORD=ledger

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
CASHBACK_RULE_CACHE_TTL_SECONDS=60
CASHBACK_RULE_CACHE_LOCK_MS=300
CASHBACK_RULE_CACHE_WAIT_MS=30

# Kafka/Redpanda
KAFKA_BROKER=localhost:9092

# Service metadata
SERVICE_NAME=sb-ledger-api
DATABASE_URL="postgresql://ledger:ledger@localhost:5432/ledger?schema=public"
